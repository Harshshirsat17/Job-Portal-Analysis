      <column caption='JobTitle_Valid' datatype='boolean' name='[Calculation_0729267824930816]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT CONTAINS(TRIM([Job Title]),&quot; &quot;)&#13;&#10;AND&#13;&#10;LEN(TRIM([Job Title])) &lt; 10' />
      </column>
      <column caption='Experience_Even' datatype='boolean' name='[Calculation_0729267825606657]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='INT([Experience]) % 2 = 0' />
      </column>
      <column caption='Contact_Contains_E' datatype='boolean' name='[Calculation_0729267825983490]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS(LOWER([Contact Person]),&quot;e&quot;)' />
      </column>
      <column caption='Test_Low' datatype='string' name='[Calculation_0729267834589188]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='SPLIT([Salary Range], &quot;-&quot;, 1)' />
      </column>
      <column caption='Salary' datatype='real' name='[Calculation_0729267835351045]' role='measure' type='quantitative'>
