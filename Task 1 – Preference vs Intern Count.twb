      <aliases enabled='yes' />
      <column caption='Company_2_Vowels' datatype='boolean' name='[Calculation_0820526901067776]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEN(REGEXP_REPLACE(LOWER([Company]), &apos;[^aeiou]&apos;, &apos;&apos;)) &gt;= 2' />
      </column>
      <column caption='Is_Even_Experience' datatype='boolean' name='[Calculation_1317249799544833]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF REGEXP_MATCH([Experience], &apos;^\d+$&apos;) THEN&#13;&#10;    INT([Experience]) % 2 = 0&#13;&#10;END' />
      </column>
      <column caption='Odd Month Filter' datatype='boolean' name='[Calculation_1317249805033474]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEPART(&apos;month&apos;, [Job Posting Date]) % 2 = 1' />
      </column>
      <column caption='IST_Time_Filter' datatype='boolean' name='[Calculation_1317249821880323]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Convert UTC to IST (UTC + 5 hours 30 minutes)&#13;&#10;DATEPART(&#13;&#10;    &apos;hour&apos;,&#13;&#10;    DATEADD(&apos;minute&apos;, 330, NOW())&#13;&#10;) &gt;= 15&#13;&#10;AND&#13;&#10;DATEPART(&#13;&#10;    &apos;hour&apos;,&#13;&#10;    DATEADD(&apos;minute&apos;, 330, NOW())&#13;&#10;) &lt; 17' />
      </column>
